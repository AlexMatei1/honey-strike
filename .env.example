# =============================================================================
# HoneyStrike — Environment Variables
# Copy to `.env` (dev) or `.env.production` (prod) and fill in values.
# Never commit the populated file.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_ENV=development               # development | production
LOG_LEVEL=INFO                    # DEBUG | INFO | WARNING | ERROR
DOMAIN=localhost                  # public domain (Caddy ACME) in production

# -----------------------------------------------------------------------------
# Database (Postgres 16)
# -----------------------------------------------------------------------------
POSTGRES_USER=honeystrike
POSTGRES_PASSWORD=change-me-honeystrike
POSTGRES_DB=honeystrike
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://honeystrike:change-me-honeystrike@postgres:5432/honeystrike

# -----------------------------------------------------------------------------
# Redis 7 (event bus + cache)
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
REDIS_STREAM=honeystrike:events
REDIS_STREAM_MAXLEN=100000

# -----------------------------------------------------------------------------
# Auth / Security
# -----------------------------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-64-hex-chars
JWT_ALGORITHM=RS256
JWT_ACCESS_TTL_SECONDS=3600
JWT_REFRESH_TTL_SECONDS=604800

# Seed admin (created on first boot if users table is empty)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong-password

# Self-service account creation on the login page. true for dev/demo;
# set false on a locked-down capture deployment (only the seed admin exists).
ALLOW_REGISTRATION=true

# -----------------------------------------------------------------------------
# Workers
# -----------------------------------------------------------------------------
WORKER_CONCURRENCY=4
SESSION_MAX_DURATION_SECONDS=300
FTP_SESSION_MAX_DURATION_SECONDS=120

# -----------------------------------------------------------------------------
# Alerting thresholds
# -----------------------------------------------------------------------------
ALERT_THRESHOLD_MEDIUM=30
ALERT_THRESHOLD_HIGH=60
ALERT_THRESHOLD_CRITICAL=80
ALERT_COOLDOWN_SECONDS=1800

# -----------------------------------------------------------------------------
# Telegram
# -----------------------------------------------------------------------------
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# -----------------------------------------------------------------------------
# Email (SMTP) — optional
# -----------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=honeystrike@example.com
SMTP_TO=

# -----------------------------------------------------------------------------
# Slack — optional
# -----------------------------------------------------------------------------
SLACK_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# Threat intel APIs
# -----------------------------------------------------------------------------
ABUSEIPDB_KEY=
ABUSEIPDB_CACHE_TTL_SECONDS=21600    # 6h

MAXMIND_ACCOUNT_ID=
MAXMIND_LICENSE_KEY=
MAXMIND_DB_DIR=/maxmind

# -----------------------------------------------------------------------------
# Reports
# -----------------------------------------------------------------------------
REPORTS_DIR=/reports
REPORTS_RETENTION_DAYS=180
REPORT_AUTO_TRIGGER_SCORE=60

# -----------------------------------------------------------------------------
# Honeypot port mappings (host:container)
# In dev on Windows: privileged ports remapped to high host ports.
# In prod: bind directly to 21/22/80/443/3389 on the public interface.
# -----------------------------------------------------------------------------
HONEYPOT_SSH_HOST_PORT=2222
HONEYPOT_HTTP_HOST_PORT=8080
HONEYPOT_HTTPS_HOST_PORT=8443
HONEYPOT_FTP_HOST_PORT=2221
HONEYPOT_RDP_HOST_PORT=33389

# -----------------------------------------------------------------------------
# SSH honeypot banner
# -----------------------------------------------------------------------------
SSH_BANNER=SSH-2.0-OpenSSH_8.9p1 Ubuntu-3ubuntu0.1
SSH_ALLOW_AFTER_N_ATTEMPTS=3
