# =============================================================================
# HoneyStrike — Production environment template
#
# Copy to `.env.production` on the VPS and fill in. NEVER commit the populated
# file. Strong passwords / random keys are required for every commented step.
#
#   cp .env.production.example .env.production
#   $EDITOR .env.production
#
# Generate cryptographic values BEFORE deployment:
#   python -c "import secrets; print(secrets.token_hex(32))"   → SECRET_KEY
#   python -c "import secrets; print(secrets.token_urlsafe(24))" → passwords
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_ENV=production
LOG_LEVEL=INFO

# Public domain. Required when Caddy + dashboard land in Phase 4. Safe to set
# to a placeholder during partial-stack deploy.
DOMAIN=honeystrike.example.com

# -----------------------------------------------------------------------------
# Database (Postgres 16) — internal-net only, not published.
# -----------------------------------------------------------------------------
POSTGRES_USER=honeystrike
POSTGRES_PASSWORD=GENERATE_ME_24_RANDOM_CHARS
POSTGRES_DB=honeystrike
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://honeystrike:GENERATE_ME_24_RANDOM_CHARS@postgres:5432/honeystrike

# -----------------------------------------------------------------------------
# Redis 7 — internal-net only, not published.
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
REDIS_STREAM=honeystrike:events
REDIS_STREAM_MAXLEN=100000

# -----------------------------------------------------------------------------
# Auth / Security
# -----------------------------------------------------------------------------
# 64 hex chars MINIMUM. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=GENERATE_ME_64_HEX_CHARS

JWT_ALGORITHM=RS256
JWT_ACCESS_TTL_SECONDS=3600
JWT_REFRESH_TTL_SECONDS=604800

# Seed admin account created on first boot of the dashboard (Phase 4). Safe to
# leave unset until then.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=GENERATE_ME_STRONG_24_CHARS_MIN

# -----------------------------------------------------------------------------
# Workers
# -----------------------------------------------------------------------------
WORKER_CONCURRENCY=4
SESSION_MAX_DURATION_SECONDS=300
FTP_SESSION_MAX_DURATION_SECONDS=120

# -----------------------------------------------------------------------------
# SSH honeypot
# -----------------------------------------------------------------------------
# Realistic-but-old banner; scanners advance past first-connection checks.
SSH_BANNER=SSH-2.0-OpenSSH_8.9p1 Ubuntu-3ubuntu0.1
SSH_ALLOW_AFTER_N_ATTEMPTS=3
SSH_ATTEMPT_COUNTER_TTL_SECONDS=3600

# -----------------------------------------------------------------------------
# Alerting (Phase 3 — partial-stack runs fine with these unset)
# -----------------------------------------------------------------------------
ALERT_THRESHOLD_MEDIUM=30
ALERT_THRESHOLD_HIGH=60
ALERT_THRESHOLD_CRITICAL=80
ALERT_COOLDOWN_SECONDS=1800

TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=honeystrike@example.com
SMTP_TO=

SLACK_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# Threat intel APIs (Phase 3)
# -----------------------------------------------------------------------------
ABUSEIPDB_KEY=
ABUSEIPDB_CACHE_TTL_SECONDS=21600

MAXMIND_ACCOUNT_ID=
MAXMIND_LICENSE_KEY=
MAXMIND_DB_DIR=/maxmind

# -----------------------------------------------------------------------------
# Reports (Phase 4)
# -----------------------------------------------------------------------------
REPORTS_DIR=/reports
REPORTS_RETENTION_DAYS=180
REPORT_AUTO_TRIGGER_SCORE=60

# -----------------------------------------------------------------------------
# Honeypot port mappings — PRODUCTION ONLY.
# These take precedence inside docker-compose.prod.yml. Unlike dev (where the
# privileged ports are remapped to high host ports), production binds to the
# real wire ports on 0.0.0.0.
#
# IMPORTANT: before `up`, ensure the VPS host's real SSH management daemon is
# NOT on port 22. Move it to e.g. 2222 in /etc/ssh/sshd_config first; see
# docs/16_Launch_Runbook.md §1.
# -----------------------------------------------------------------------------
HONEYPOT_SSH_HOST_PORT=22
HONEYPOT_HTTP_HOST_PORT=80
HONEYPOT_HTTPS_HOST_PORT=443
HONEYPOT_FTP_HOST_PORT=21
HONEYPOT_RDP_HOST_PORT=3389
