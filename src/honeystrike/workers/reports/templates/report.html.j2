<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>HoneyStrike — Session {{ session.id }}</title>
  <style>
    :root {
      --bg: #0e1116;
      --bg-elev: #161b22;
      --bg-elev-2: #1f2530;
      --fg: #e6edf3;
      --muted: #8b949e;
      --accent: #58a6ff;
      --low: #5fb878;
      --medium: #d29922;
      --high: #f0883e;
      --critical: #f85149;
      --border: #30363d;
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      background: var(--bg);
      color: var(--fg);
      font-family: ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
      line-height: 1.45;
    }
    .container { max-width: 980px; margin: 0 auto; padding: 24px; }
    h1 { margin: 0 0 4px 0; font-size: 1.4rem; }
    h2 { font-size: 1.05rem; margin: 0 0 8px 0; }
    .muted { color: var(--muted); font-size: 0.85rem; }
    code, pre { font-family: ui-monospace, "JetBrains Mono", Consolas, monospace; }
    pre { background: var(--bg-elev-2); padding: 8px; border-radius: 6px; overflow-x: auto; font-size: 0.8rem; }
    .header {
      display: flex; align-items: center; justify-content: space-between;
      gap: 16px; margin-bottom: 16px; flex-wrap: wrap;
    }
    .score-pill {
      display: inline-block; padding: 4px 12px; border-radius: 999px;
      font-weight: 700; color: #0b1322; font-size: 0.95rem;
    }
    .score-low      { background: var(--low); }
    .score-medium   { background: var(--medium); }
    .score-high     { background: var(--high); }
    .score-critical { background: var(--critical); color: #fff; }
    details {
      background: var(--bg-elev);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 12px 16px;
      margin-bottom: 12px;
    }
    details > summary {
      cursor: pointer;
      font-weight: 600;
      list-style: none;
      display: flex; align-items: center; justify-content: space-between;
    }
    details > summary::after { content: " ▾"; color: var(--muted); }
    details[open] > summary::after { content: " ▴"; }
    table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
    th, td { padding: 6px 8px; text-align: left; border-bottom: 1px solid var(--border); vertical-align: top; }
    th { color: var(--muted); font-weight: 500; width: 30%; }
    .kv td { font-family: ui-monospace, Consolas, monospace; word-break: break-all; }
    .footer { color: var(--muted); font-size: 0.8rem; text-align: center; margin-top: 24px; }
  </style>
</head>
<body>
  <main class="container">
    <header class="header">
      <div>
        <h1>HoneyStrike threat-intel report</h1>
        <div class="muted">Session <code>{{ session.id }}</code> &middot; generated {{ generated_at }}</div>
      </div>
      <div class="score-pill score-{{ session.severity }}">{{ session.severity|upper }} &middot; {{ session.threat_score }}/100</div>
    </header>

    <details open>
      <summary>Source</summary>
      <table class="kv">
        <tr><th>IP</th><td><code>{{ session.src_ip }}</code></td></tr>
        {% if fingerprint %}
        <tr><th>Country</th><td>{{ fingerprint.country_iso or '—' }}{% if fingerprint.country_name %} — {{ fingerprint.country_name }}{% endif %}</td></tr>
        <tr><th>City</th><td>{{ fingerprint.city or '—' }}</td></tr>
        <tr><th>ASN</th><td>{% if fingerprint.asn %}AS{{ fingerprint.asn }}{% if fingerprint.org %} ({{ fingerprint.org }}){% endif %}{% else %}—{% endif %}</td></tr>
        <tr><th>AbuseIPDB score</th><td>{% if fingerprint.abuse_score is not none %}{{ fingerprint.abuse_score }}/100 ({{ fingerprint.abuse_reports or 0 }} reports){% else %}—{% endif %}</td></tr>
        <tr><th>JA3</th><td>{{ fingerprint.ja3_hash or '—' }}</td></tr>
        {% endif %}
      </table>
    </details>

    <details open>
      <summary>Session</summary>
      <table class="kv">
        <tr><th>Service</th><td>{{ session.service }}</td></tr>
        <tr><th>State</th><td>{{ session.state }}</td></tr>
        <tr><th>Threat score</th><td>{{ session.threat_score }}/100 ({{ session.severity }})</td></tr>
        <tr><th>Started</th><td>{{ session.started_at }}</td></tr>
        <tr><th>Ended</th><td>{{ session.ended_at or '—' }}</td></tr>
        <tr><th>Duration</th><td>{% if session.duration_ms %}{{ session.duration_ms }} ms{% else %}—{% endif %}</td></tr>
        <tr><th>Event count</th><td>{{ session.event_count }}</td></tr>
        {% if fingerprint and fingerprint.timing_pattern %}
        <tr><th>Timing pattern</th><td>{{ fingerprint.timing_pattern }}{% if fingerprint.attempt_rate_rpm %} ({{ fingerprint.attempt_rate_rpm }} rpm){% endif %}</td></tr>
        {% endif %}
      </table>
    </details>

    <details {% if fingerprint and fingerprint.tool_signatures %}open{% endif %}>
      <summary>Tool signatures</summary>
      {% if fingerprint and fingerprint.tool_signatures %}
        <table>
          <thead><tr><th style="width:auto">Name</th><th style="width:30%">Confidence</th></tr></thead>
          <tbody>
            {% for sig in fingerprint.tool_signatures %}
              <tr><td>{{ sig.name }}</td><td>{{ "%.2f"|format(sig.confidence) }}</td></tr>
            {% endfor %}
          </tbody>
        </table>
      {% else %}
        <p class="muted">No tool signatures matched.</p>
      {% endif %}
    </details>

    <details {% if ttps %}open{% endif %}>
      <summary>MITRE ATT&amp;CK attribution</summary>
      {% if ttps %}
        <table>
          <thead><tr><th style="width:18%">Technique</th><th>Name</th><th style="width:25%">Tactic</th><th style="width:15%">Confidence</th></tr></thead>
          <tbody>
            {% for t in ttps %}
              <tr>
                <td><code>{{ t.technique_id }}</code></td>
                <td>{{ t.technique_name }}</td>
                <td>{{ t.tactic }}</td>
                <td>{{ "%.2f"|format(t.confidence) }}</td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      {% else %}
        <p class="muted">No techniques attributed.</p>
      {% endif %}
    </details>

    <details>
      <summary>Event preview ({{ events|length }} of {{ session.event_count }})</summary>
      {% if events %}
        <table>
          <thead><tr><th style="width:18%">Time</th><th style="width:22%">Type</th><th>Payload</th></tr></thead>
          <tbody>
            {% for e in events %}
              <tr>
                <td>{{ e.timestamp }}</td>
                <td>{{ e.event_type }}</td>
                <td><pre>{{ e.payload_repr }}</pre></td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      {% else %}
        <p class="muted">No events captured.</p>
      {% endif %}
    </details>

    <details>
      <summary>Alerts dispatched</summary>
      {% if alerts %}
        <table>
          <thead><tr><th style="width:18%">Channel</th><th style="width:18%">Severity</th><th>When</th></tr></thead>
          <tbody>
            {% for a in alerts %}
              <tr><td>{{ a.channel }}</td><td>{{ a.severity }}</td><td>{{ a.dispatched_at }}</td></tr>
            {% endfor %}
          </tbody>
        </table>
      {% else %}
        <p class="muted">No alerts dispatched for this session.</p>
      {% endif %}
    </details>

    <p class="footer">HoneyStrike — generated {{ generated_at }}</p>
  </main>
</body>
</html>
