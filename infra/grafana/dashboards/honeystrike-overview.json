      "targets": [
        {
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT date_trunc('hour', started_at) AS time, service AS metric, count(*) AS value FROM sessions WHERE $__timeFilter(started_at) GROUP BY 1, 2 ORDER BY 1",
          "refId": "A"
        }
      ],
      "title": "Sessions per hour by service",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "postgres", "uid": "${DS_POSTGRES}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
