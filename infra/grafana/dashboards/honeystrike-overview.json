      "targets": [
        {
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT date_trunc('hour', started_at) AS time, 'avg_score' AS metric, round(avg(threat_score)::numeric, 1) AS value FROM sessions WHERE $__timeFilter(started_at) GROUP BY 1 ORDER BY 1",
          "refId": "A"
        }
      ],
      "title": "Average threat score per hour",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "postgres", "uid": "${DS_POSTGRES}"},
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 12},
      "id": 9,
      "options": {"displayLabels": ["percent"]},
      "targets": [
        {
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT severity, count(*) FROM sessions WHERE $__timeFilter(started_at) GROUP BY severity ORDER BY count(*) DESC",
          "refId": "A"
        }
      ],
      "title": "Severity breakdown",
      "type": "piechart"
    },
    {
      "datasource": {"type": "postgres", "uid": "${DS_POSTGRES}"},
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 12},
      "id": 10,
      "targets": [
        {
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT t.technique_id || ' — ' || t.technique_name AS technique, count(*) AS count FROM ttp_matches t JOIN sessions s ON s.id = t.session_id WHERE $__timeFilter(s.started_at) GROUP BY 1 ORDER BY count DESC LIMIT 10",
          "refId": "A"
        }
      ],
      "title": "Top MITRE techniques",
      "type": "table"
    },
    {
      "datasource": {"type": "postgres", "uid": "${DS_POSTGRES}"},
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 12},
      "id": 11,
      "targets": [
        {
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT coalesce(f.country_iso, '??') AS country, count(*) AS sessions FROM fingerprints f JOIN sessions s ON s.id = f.session_id WHERE $__timeFilter(s.started_at) GROUP BY 1 ORDER BY sessions DESC LIMIT 15",
          "refId": "A"
        }
      ],
      "title": "Top source countries",
      "type": "table"
    },
    {
      "datasource": {"type": "postgres", "uid": "${DS_POSTGRES}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20},
      "id": 12,
      "targets": [
        {
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT s.src_ip AS ip, count(*) AS sessions, max(s.threat_score) AS max_score, max(s.severity) AS max_severity FROM sessions s WHERE $__timeFilter(s.started_at) GROUP BY s.src_ip ORDER BY max_score DESC, sessions DESC LIMIT 20",
          "refId": "A"
        }
      ],
      "title": "Top source IPs (by max threat score)",
      "type": "table"
    },
    {
      "datasource": {"type": "postgres", "uid": "${DS_POSTGRES}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 20},
      "id": 13,
      "targets": [
        {
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT a.dispatched_at AS time, a.channel, a.severity, a.threat_score, a.payload->>'src_ip' AS src_ip FROM alerts a WHERE $__timeFilter(a.dispatched_at) ORDER BY a.dispatched_at DESC LIMIT 25",
          "refId": "A"
        }
      ],
      "title": "Recent alerts",
      "type": "table"
    }
