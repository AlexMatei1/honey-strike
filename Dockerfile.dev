# Development image — Python 3.13 + Poetry, repo mounted as volume.
# Lets you run alembic / pytest / honeypot services without installing
# Python or Poetry on the Windows host.

FROM python:3.13-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    POETRY_VERSION=2.4.1 \
    POETRY_VIRTUALENVS_CREATE=false \
    POETRY_NO_INTERACTION=1 \
    PYTHONPATH=/app/src

RUN apt-get update && apt-get install -y --no-install-recommends \
        build-essential \
        libpq-dev \
        libffi-dev \
        libssl-dev \
        curl \
        # WeasyPrint runtime libs (PDF rendering used by the report worker).
        libpango-1.0-0 \
        libpangoft2-1.0-0 \
        libharfbuzz0b \
        libcairo2 \
        libgdk-pixbuf-2.0-0 \
        fonts-dejavu-core \
        shared-mime-info \
    && rm -rf /var/lib/apt/lists/* \
    && pip install --no-cache-dir "poetry==${POETRY_VERSION}"

WORKDIR /app

# Install dependencies first so the layer is cached across code edits.
COPY pyproject.toml ./
RUN poetry install --no-root --with dev
# `--no-root` skips installing the project itself; sources are mounted.
# Some prod-style hardening (read-only rootfs, weasyprint system libs) is
# deferred to the prod Dockerfile.

# Sources mounted at runtime via docker-compose volume.
CMD ["python", "-c", "print('honeystrike dev image ready')"]
